# Base URL of the GitRank backend API. If unset, the app falls back to
# http://localhost:3000 in dev. Override at any time by appending ?api=<url>
# to the site URL — useful for QAing against a staging deploy.
#
# Production deploy on Render:
#   VITE_API_BASE=https://gitrank-backend.onrender.com
# (must be https:// — GitHub Pages is HTTPS-only, so a browser will block a
#  fetch to http:// as mixed content even though Render 301s HTTP→HTTPS.)
VITE_API_BASE=http://localhost:3000
