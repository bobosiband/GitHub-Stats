# ── GitRank backend environment ────────────────────────────────────────────
# Copy to `.env` and fill in. All variables are validated at boot (src/config.js);
# the process exits with a readable error if anything is missing or malformed.

# Postgres connection string. Matches the docker-compose service below.
DATABASE_URL="postgresql://gitrank:gitrank@localhost:5432/gitrank?schema=public"

# GitHub Personal Access Token (classic or fine-grained) used by the sync job.
# Only needs read access to PUBLIC data: public_repo / read:user is plenty.
# Get one at https://github.com/settings/tokens
GITHUB_TOKEN="ghp_replace_me"

# Static bearer token guarding /admin/* routes. Generate a long random string.
ADMIN_TOKEN="change-me-to-a-long-random-string"

# Cron expression for the scheduled sync. Default: every 3 hours.
SYNC_CRON="0 */3 * * *"

# HTTP port.
PORT=3000

# Log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Set to "false" to build the app without registering the cron job (tests do this).
ENABLE_CRON=true

# Comma-separated list of origins allowed to hit the API (CORS). Empty ⇒ no
# browser origins allowed. Include the frontend's local dev URL first.
CORS_ORIGIN="http://localhost:5173"
